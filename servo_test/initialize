from gpiozero import Servo, Device
from gpiozero.pins.pigpio import PiGPIOFactor
from time import sleep

Device.pin_factory = PiGPIOFactory()
servo = Servo(18) #GPIO pin for servo

# Initial Position Testing
servo.min()
sleep(1)
servo.mid()
sleep(1)
servo.max()
sleep(1)
servo.detach()

# Specific Position Testing
servo.value = 0
sleep(2)

servo.value = 0.5
sleep(2)